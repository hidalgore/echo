# Copy to backend/.env for local dev (loaded by echo_api.settings.dev).
# NEVER commit backend/.env.

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# docker-compose services (see repo-root docker-compose.yml)
POSTGRES_DB=echo
POSTGRES_USER=echo
POSTGRES_PASSWORD=echo
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Served by /v1/config/public
ECHO_MIN_APP_VERSION=9.0.0

# Stripe test-mode slots (wired in Phase 3; leave empty until then)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry slot (initialized in staging/prod settings when set)
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
